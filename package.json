{
  "name": "merlin",
  "version": "0.1.0",
  "description": "Merlin Mirror - AI-powered spell casting experience",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:spout": "vite -- --spout",
    "build": "tsc && vite build",
    "start": "electron .",
    "start:spout": "electron . --spout",
    "rebuild": "electron-rebuild",
    "dist": "npm run build && electron-builder --win --dir",
    "dist:installer": "npm run build && electron-builder --win",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.21.0",
    "@huggingface/transformers": "^4.2.0",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@napolab/texture-bridge-core": "^0.10.0",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "electron": "^41.3.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "svg2img": "^1.0.0-beta.2",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.fivestone.merlin",
    "productName": "Merlin",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": "dir",
      "icon": "build/icon.ico"
    }
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
