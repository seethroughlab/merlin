{
  "name": "merlin",
  "version": "1.0.0-handoff",
  "description": "Merlin Mirror - AI-powered spell casting experience",
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "node scripts/kill-stale-merlin.cjs",
    "dev": "vite",
    "dev:spout": "vite -- --spout",
    "build": "tsc && vite build",
    "start": "electron .",
    "start:spout": "electron . --spout",
    "rebuild": "electron-rebuild",
    "dist": "npm run build && electron-builder --win --dir",
    "dist:installer": "npm run build && electron-builder --win",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@google/genai": "^1.50.1",
    "@huggingface/transformers": "^4.2.0",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@napolab/texture-bridge-core": "^0.10.0",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "pptxgenjs": "^3.12.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^41.3.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.3.0",
    "svg2img": "^1.0.0-beta.2",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.fivestone.merlin",
    "productName": "Merlin",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "shaders",
        "to": "shaders",
        "filter": [
          "**/*.glsl"
        ]
      }
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico"
    }
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
